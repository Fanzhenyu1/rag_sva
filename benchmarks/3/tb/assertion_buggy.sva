`timescale 1ns/10ps

module v_dut_buggy
    #(
    parameter NB_PERIPHERALS = 4,
    parameter PRIV_TYPES = 2
    )
    (
    clk, 
    rst, 
    acc_ctrl, 
    acc_ctrl_c
    );

    input clk;
    input rst;
    
    input logic [PRIV_TYPES*NB_PERIPHERALS-1 :0]   acc_ctrl; // Access control values
    input logic [PRIV_TYPES-1:0][NB_PERIPHERALS-1:0] acc_ctrl_c;

    // assertion here
    ///////////////  Assertion 1 /////////////////
    genvar priv, peripheral;
    generate
        for (priv=0; priv < PRIV_TYPES; priv++) begin
            for (peripheral=0; peripheral < NB_PERIPHERALS; peripheral++) begin
                assert property (@(posedge clk) (acc_ctrl_c[priv][peripheral] == acc_ctrl[peripheral*PRIV_TYPES+priv]) ); 
            end
        end       
    endgenerate 

endmodule

bind tb 
    v_dut_buggy
    #(
    .NB_PERIPHERALS(NB_PERIPHERALS),
    .PRIV_TYPES(PRIV_TYPES)
    )
    i_bind_dut_buggy
    (
    .clk           (clk          ),
    .rst           (rst          ),
    .acc_ctrl      (acc_ctrl     ),
    .acc_ctrl_c    (acc_ctrl_c   )
); 

    
